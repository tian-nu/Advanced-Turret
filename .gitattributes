# 统一文本文件行为 LF，避免提交时反复提示行尾转换
* text=auto eol=lf

# Windows 脚本保留 CRLF，方便本地双击或 cmd/powershell 调用
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 常见二进制资源禁止行尾转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.gz binary
*.7z binary
*.dll binary
*.so binary
*.pdf binary
